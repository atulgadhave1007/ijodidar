# ── Core ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-32-chars-random
FLASK_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ijodidar_user:password@your-rds-endpoint:5432/ijodidar

# ── AWS S3 (profile images) ───────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ijodidar-images
# Not needed on EC2 with IAM role. Set for local dev only:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ── AWS SES (transactional email) ─────────────────────────────────────────
MAIL_FROM=noreply@ijodidar.in

# ── Razorpay (payment gateway) ────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
# Test keys: rzp_test_... (no real money charged)

# ── MSG91 (SMS OTP) ───────────────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=IJODDR
MSG91_TEMPLATE_ID=your-template-id

# ── Admin ─────────────────────────────────────────────────────────────────
ADMIN_EMAILS=youremail@gmail.com,another@gmail.com

# ── Optional: Redis for rate limiting ─────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Aadhaar / ID Verification (Phase 14.2) ─────────────────────────────────
# Provider: Surepass (surepass.io) — ₹10-20 per verification
# Create account at https://surepass.io → API → Aadhaar OTP
KYC_API_KEY=your-surepass-api-key
KYC_PROVIDER=surepass
# Leave blank for dev mode — any 6-digit OTP passes

# ── WhatsApp Business API (Phase 14.3) ─────────────────────────────────────
# Setup: Meta Business → WhatsApp Business → API → Phone Number
# Free: 1,000 conversations/month
WHATSAPP_TOKEN=EAAxxxx...your-meta-token
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Leave blank for dev mode — messages logged to console
